# Database (Neon PostgreSQL ou Supabase)
# Para produção serverless, use a URL do connection pooler (porta 6543 no Supabase)
DATABASE_URL="postgresql://user:password@host:6543/dbname?sslmode=require&pgbouncer=true"
# URL direta para migrações Prisma (sem pooler)
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth — OBRIGATÓRIO em produção (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Exchange Rates API
BCP_API_URL="https://www.bcp.gov.py/api/tasas-cambio"
EXCHANGERATE_API_KEY="your-exchangerate-api-key"

# SIFEN (Autoridade Fiscal do Paraguai)
SIFEN_API_URL="https://sifen.set.gov.py/api"
SIFEN_CERTIFICATE="base64-encoded-p12-certificate"
SIFEN_CERTIFICATE_PASS="certificate-password"

# Vercel Blob (armazenamento de XMLs SIFEN)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# Google Gemini AI (para AI Invoice Importer)
GEMINI_API_KEY="your-gemini-api-key"

# Anthropic Claude (Conselheiro AXIS advisor — habilite o web_search nas configurações de privacidade do Console)
ANTHROPIC_API_KEY="your-anthropic-api-key"
