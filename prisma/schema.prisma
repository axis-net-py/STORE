generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────

enum Role {
  SOVEREIGN
  ADMIN
  OPERATOR
  AUDITOR
}

enum Currency {
  PYG
  USD
  BRL
}

enum TransactionType {
  RECEIVABLE
  PAYABLE
  TRANSFER
}

enum InvoiceType {
  PURCHASE
  SALES
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  CANCELLED
  PENDING
}

enum MovementType {
  ENTRADA
  SAIDA
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CARD
  OTHER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum TaxType {
  IVA_10
  IVA_5
  EXENTO
}

// ─── Tenant ─────────────────────────────────────────────────

model Tenant {
  id               String   @id @default(cuid())
  name             String
  businessName     String?
  ruc              String?
  tradeName        String?
  establishment    String?  @default("001")
  emissionPoint    String?  @default("001")
  address          String?
  economicActivity String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users             User[]
  customers         Customer[]
  suppliers         Supplier[]
  products          Product[]
  invoices          CommercialInvoice[]
  exchangeRates     ExchangeRate[]
  accounts          Account[]
  transactions      Transaction[]
  permissions       Permission[]
  journalEntries    JournalEntry[]
  auditLogs         AuditLog[]
  orders            Order[]
  warehouses        Warehouse[]
  accountingPeriods AccountingPeriod[]
  payments          Payment[]
}

// ─── User ───────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  password           String
  role               Role      @default(OPERATOR)
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  emailVerified      DateTime?
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now())

  @@index([tenantId])
}

// ─── Customer ───────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  document     String?
  documentType String? // RUC, CI, CPF, CNPJ
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?  @default("PY")
  category     String?  @default("retail") // retail, wholesale, vip
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoices CommercialInvoice[]
  orders   Order[]

  @@index([tenantId])
}

// ─── Supplier ───────────────────────────────────────────────

model Supplier {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  businessName String?
  document     String?
  documentType String? // RUC, CI, CPF, CNPJ
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?  @default("PY")
  category     String?  @default("retail")
  isActive     Boolean  @default(true)
  paymentTerms String? // e.g. "30 days", "Net 60"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseInvoices CommercialInvoice[]
  orders           Order[]

  @@index([tenantId])
}

// ─── Product ────────────────────────────────────────────────

model Product {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  sku          String
  name         String
  price        Decimal  @db.Decimal(12, 2)
  cost         Decimal  @default(0) @db.Decimal(12, 2)
  currency     Currency @default(PYG)
  unit         String   @default("un")
  taxType      TaxType  @default(IVA_10)
  currentStock Decimal  @default(0) @db.Decimal(10, 2)
  minStock     Decimal  @default(0) @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  tags         String?
  isService    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements       InventoryMovement[]
  invoiceItems    InvoiceItem[]
  orderItems      OrderItem[]
  warehouseStocks WarehouseStock[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

// ─── Commercial Invoice ─────────────────────────────────────

model CommercialInvoice {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  type           InvoiceType
  status         InvoiceStatus @default(APPROVED)
  documentNumber String?
  timbrado       String?
  sifenCdc       String?
  sifenXmlUrl    String?
  sifenStatus    String?
  attachmentUrl  String?
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  supplierId     String?
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  issuedAt       DateTime      @default(now())
  dueDate        DateTime?
  currency       Currency      @default(PYG)
  exchangeRate   Decimal       @default(1) @db.Decimal(12, 4)
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  totalUSD       Decimal?      @db.Decimal(12, 2)
  totalIva10     Decimal       @default(0) @db.Decimal(12, 2)
  totalIva5      Decimal       @default(0) @db.Decimal(12, 2)
  totalExento    Decimal       @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items     InvoiceItem[]
  movements InventoryMovement[]
  payments  Payment[]

  @@index([tenantId])
  @@index([customerId])
  @@index([supplierId])
}

// ─── Invoice Item ───────────────────────────────────────────

model InvoiceItem {
  id                  String            @id @default(cuid())
  commercialInvoiceId String
  commercialInvoice   CommercialInvoice @relation(fields: [commercialInvoiceId], references: [id])
  productId           String
  product             Product           @relation(fields: [productId], references: [id])
  sku                 String?
  quantity            Decimal           @db.Decimal(10, 2)
  unitPrice           Decimal           @db.Decimal(12, 2)
  totalPrice          Decimal           @db.Decimal(12, 2)
  taxType             TaxType           @default(IVA_10)
  taxBase             Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal           @default(0) @db.Decimal(12, 2)
  cost                Decimal?          @db.Decimal(12, 2)

  @@index([commercialInvoiceId])
  @@index([productId])
}

// ─── Inventory Movement ─────────────────────────────────────

model InventoryMovement {
  id                  String             @id @default(cuid())
  tenantId            String
  productId           String
  product             Product            @relation(fields: [productId], references: [id])
  type                MovementType
  quantity            Decimal            @db.Decimal(10, 2)
  unitCost            Decimal?           @db.Decimal(12, 2)
  totalCost           Decimal?           @db.Decimal(12, 2)
  reason              String?
  warehouseId         String?
  warehouse           Warehouse?         @relation(fields: [warehouseId], references: [id])
  commercialInvoiceId String?
  commercialInvoice   CommercialInvoice? @relation(fields: [commercialInvoiceId], references: [id])
  createdAt           DateTime           @default(now())

  @@index([tenantId])
  @@index([productId])
}

// ─── Exchange Rate ──────────────────────────────────────────

model ExchangeRate {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  ratePYGtoUSD Decimal  @db.Decimal(12, 4)
  ratePYGtoBRL Decimal  @db.Decimal(12, 4)
  date         DateTime @default(now())
  source       String   @default("manual")
  isManual     Boolean  @default(false)

  @@index([tenantId])
  @@index([date])
}

// ─── Account (Chart of Accounts) ────────────────────────────

model Account {
  id       String      @id @default(cuid())
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  code     String
  namePt   String
  nameEs   String
  type     AccountType
  isActive Boolean     @default(true)

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ─── Transaction ────────────────────────────────────────────

model Transaction {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  type         TransactionType
  entityId     String
  currency     Currency        @default(PYG)
  amount       Decimal         @db.Decimal(12, 2)
  exchangeRate Decimal         @default(1) @db.Decimal(12, 4)
  totalPyg     Decimal         @db.Decimal(12, 2)
  category     String?
  createdAt    DateTime        @default(now())

  @@index([tenantId])
}

// ─── Permission ─────────────────────────────────────────────

model Permission {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  action   String
  role     Role

  @@unique([action, role, tenantId])
  @@index([tenantId])
}

// ─── Journal Entry ──────────────────────────────────────────

model JournalEntry {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  number        String
  date          DateTime
  description   String
  status        String    @default("DRAFT") // POSTED, DRAFT, VOIDED
  referenceType String?
  referenceId   String?
  postedAt      DateTime?
  createdBy     String?
  createdAt     DateTime  @default(now())

  lines JournalLine[]

  @@index([tenantId])
}

// ─── Journal Line ───────────────────────────────────────────

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  type           String // DEBIT, CREDIT
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @default("PYG")
  exchangeRate   Decimal      @default(1) @db.Decimal(12, 4)
  amountUSD      Decimal?     @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())

  @@index([journalEntryId])
  @@index([accountId])
}

// ─── Audit Log ──────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([entity, entityId])
}

// ─── Payment (baixa de títulos — Contas a Receber / Pagar) ─────────

model Payment {
  id                  String            @id @default(cuid())
  tenantId            String
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  commercialInvoiceId String
  commercialInvoice   CommercialInvoice @relation(fields: [commercialInvoiceId], references: [id])
  amount              Decimal           @db.Decimal(12, 2)
  currency            Currency          @default(PYG)
  exchangeRate        Decimal           @default(1) @db.Decimal(12, 4)
  method              PaymentMethod     @default(CASH)
  paidAt              DateTime          @default(now())
  notes               String?
  journalEntryId      String?
  createdBy           String?
  createdAt           DateTime          @default(now())

  @@index([tenantId])
  @@index([commercialInvoiceId])
}

// ─── Order (Pedidos de Compra/Venda — pré-faturamento) ─────────────

enum OrderStatus {
  DRAFT
  CONFIRMED
  INVOICED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  type        InvoiceType
  status      OrderStatus @default(DRAFT)
  orderNumber String
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  supplierId  String?
  supplier    Supplier?   @relation(fields: [supplierId], references: [id])
  expectedAt  DateTime?
  currency    Currency    @default(PYG)
  totalAmount Decimal     @default(0) @db.Decimal(12, 2)
  notes       String?
  invoiceId   String?
  createdBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items OrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([supplierId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Decimal @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(12, 2)

  @@index([orderId])
}

// ─── Warehouse (Multi-depósito) ─────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  code      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  stocks    WarehouseStock[]
  movements InventoryMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model WarehouseStock {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Decimal   @default(0) @db.Decimal(10, 2)

  @@unique([warehouseId, productId])
  @@index([productId])
}

// ─── Accounting Period (fechamento contábil por mês) ────────────────
// A existência de uma linha significa que o mês está FECHADO.

model AccountingPeriod {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  year     Int
  month    Int
  closedAt DateTime @default(now())
  closedBy String?

  @@unique([tenantId, year, month])
  @@index([tenantId])
}
